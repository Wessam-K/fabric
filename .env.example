# WK-Factory v3.7 — Environment Variables
# Copy this file to .env and customize

# ═══════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════
NODE_ENV=production
PORT=9002

# ═══════════════════════════════════════════════
# Auth — JWT (auto-generated and saved to .jwt_secret if not set)
# ═══════════════════════════════════════════════
# JWT_SECRET=              # min 64 chars; also used to derive webhook encryption key
# JWT_EXPIRY=24h

# ═══════════════════════════════════════════════
# Database (Electron uses %APPDATA%/WK-Factory by default)
# ═══════════════════════════════════════════════
# WK_DB_DIR=./backend      # Override default DB directory

# ═══════════════════════════════════════════════
# File Upload
# ═══════════════════════════════════════════════
# UPLOAD_DIR=./uploads     # Default: WK_DB_DIR/uploads
# MAX_FILE_SIZE_MB=10

# ═══════════════════════════════════════════════
# Rate Limiting
# ═══════════════════════════════════════════════
# LOGIN_RATE_LIMIT=20      # max attempts per 15 minutes
# LOGIN_LOCKOUT_DURATION=15 # minutes
# LOGIN_MAX_ATTEMPTS=5     # before account lockout

# ═══════════════════════════════════════════════
# SMTP — Email (password reset, notifications)
# ═══════════════════════════════════════════════
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false        # true for port 465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
# APP_BASE_URL=https://your-domain.com  # used in password reset links

# ═══════════════════════════════════════════════
# Licensing (HMAC validation)
# ═══════════════════════════════════════════════
# LICENSE_HMAC_SECRET=     # secret key for HMAC-SHA256 license validation

# ═══════════════════════════════════════════════
# Report & Query Limits
# ═══════════════════════════════════════════════
# MAX_REPORT_ROWS=5000     # Maximum rows returned by report queries

# ═══════════════════════════════════════════════
# Auto-backup interval
# ═══════════════════════════════════════════════
# AUTO_BACKUP_HOURS=6      # Hours between automatic backups

# ═══════════════════════════════════════════════
# Sentry error tracking (optional)
# ═══════════════════════════════════════════════
# SENTRY_DSN=              # https://xxx@xxx.ingest.sentry.io/xxx

# ═══════════════════════════════════════════════
# Logging (Winston in production, console in test)
# ═══════════════════════════════════════════════
# LOG_LEVEL=info           # error, warn, info, debug

# ═══════════════════════════════════════════════
# CORS
# ═══════════════════════════════════════════════
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ═══════════════════════════════════════════════
# Electron (set automatically by Electron wrapper)
# ═══════════════════════════════════════════════
# ELECTRON_APP=1           # disables secure-only cookies in Electron
