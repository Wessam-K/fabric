# WK-Factory v3.0 — Environment Variables
# Copy this file to .env and customize

# Server
NODE_ENV=production
PORT=9002

# Auth (auto-generated if not set)
# JWT_SECRET=              # min 64 chars, auto-generated and saved to .jwt_secret if not set
# JWT_EXPIRY=24h

# Database (Electron uses %APPDATA%/WK-Factory by default)
# WK_DB_DIR=./backend      # Override default DB directory

# File Upload
# UPLOAD_DIR=./uploads     # Default: WK_DB_DIR/uploads
# MAX_FILE_SIZE_MB=10

# Rate Limiting
# LOGIN_RATE_LIMIT=20      # max attempts per 15 minutes
# LOGIN_LOCKOUT_DURATION=15 # minutes
# LOGIN_MAX_ATTEMPTS=5     # before account lockout

# Phase 2.4: Report query limits
# MAX_REPORT_ROWS=5000     # Maximum rows returned by report queries

# Phase 2.5: Auto-backup interval
# AUTO_BACKUP_HOURS=6      # Hours between automatic backups

# Phase 5.3: Sentry error tracking (optional)
# SENTRY_DSN=              # https://xxx@xxx.ingest.sentry.io/xxx

# Logging
# LOG_LEVEL=info           # error, warn, info, debug

# CORS
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
