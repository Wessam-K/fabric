# WK-Factory — Backend Environment Variables
PORT=9002
NODE_ENV=development

# Auth (auto-generated and saved to .jwt_secret if not set)
# JWT_SECRET=
# JWT_EXPIRY=24h

# Database
# WK_DB_DIR=./   # directory for wk-hub.db

# Rate Limiting
# LOGIN_RATE_LIMIT=20
# LOGIN_LOCKOUT_DURATION=15
# LOGIN_MAX_ATTEMPTS=5

# Reports
# MAX_REPORT_ROWS=5000

# Auto-backup interval (hours)
# AUTO_BACKUP_HOURS=6

# Sentry error tracking (optional)
# SENTRY_DSN=

# Logging
# LOG_LEVEL=info

# CORS
# CORS_ORIGIN=http://localhost:5173
