{
  "name": "wk-hub",
  "version": "2.0.0",
  "description": "WK-Hub — نظام إدارة المصنع",
  "main": "electron.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "seed": "cd backend && node seed.js",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "electron:dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npx wait-on http://localhost:9173 && npx electron .\"",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend && npx electron-builder --win",
    "test": "cd backend && node --test tests/api.test.js",
    "test:backend": "cd backend && node --test tests/api.test.js"
  },
  "build": {
    "appId": "com.wkhub.factory",
    "productName": "WK-Hub",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!*.db",
          "!*.db-shm",
          "!*.db-wal",
          "!uploads/**"
        ]
      },
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules",
        "filter": ["**/*"]
      },
      {
        "from": "frontend/dist",
        "to": "frontend/dist",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "dir", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}
